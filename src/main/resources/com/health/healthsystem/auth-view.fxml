<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox spacing="20" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.health.healthsystem.controller.AuthController"
      style="-fx-padding: 30; -fx-background-color: white;">

    <Label text="Clinic Portal" style="-fx-font-size: 24; -fx-font-weight: bold;"/>

    <TabPane tabClosingPolicy="UNAVAILABLE">
        <Tab text="Login">
            <VBox spacing="10" style="-fx-padding: 20;">
                <TextField fx:id="loginUsernameField" promptText="Username"/>
                <PasswordField fx:id="loginPasswordField" promptText="Password"/>
                <Button text="Login" onAction="#handleLogin" maxWidth="Infinity" style="-fx-background-color: #1565c0; -fx-text-fill: white;"/>
            </VBox>
        </Tab>
        <Tab text="Register">
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                <VBox spacing="10" style="-fx-padding: 20;">
                    <TextField fx:id="regUsername" promptText="Username (Login ID)"/>
                    <PasswordField fx:id="regPassword" promptText="Password"/>
                    <Separator/>
                    <TextField fx:id="regFullName" promptText="Full Legal Name"/>
                    <DatePicker fx:id="regBirthDate" promptText="Date of Birth" maxWidth="Infinity"/>
                    <ComboBox fx:id="regGender" promptText="Gender" maxWidth="Infinity">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="MALE"/>
                                <String fx:value="FEMALE"/>
                                <String fx:value="OTHER"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                    <ComboBox fx:id="regRole" promptText="Account Type" maxWidth="Infinity" onAction="#toggleSpecialtyField">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="PATIENT"/>
                                <String fx:value="DOCTOR"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                    <TextField fx:id="regSpecialty" promptText="Specialization (Doctors only)" visible="false" managed="false"/>
                    <Button text="Create Account" onAction="#handleSignup" maxWidth="Infinity"/>
                </VBox>
            </ScrollPane>
        </Tab>
    </TabPane>
    <Label fx:id="statusLabel" textFill="red"/>
</VBox>