<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.health.healthsystem.controller.AuthController"
      spacing="0" style="-fx-background-color: #f5f5f5;">

    <!-- Header -->
    <HBox style="-fx-background-color: #1565c0; -fx-padding: 16 24 16 24;">
        <Label text="🏥  Healthcare Management System"
               style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
    </HBox>

    <TabPane fx:id="authTabPane" tabClosingPolicy="UNAVAILABLE"
             style="-fx-background-color: #f5f5f5;">

        <!-- ══ LOGIN TAB ══════════════════════════════════════════════════════ -->
        <Tab text="Login">
            <VBox spacing="16" style="-fx-padding: 36 48 36 48; -fx-background-color: #f5f5f5;">
                <Label text="Sign in to your account"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
                <Separator/>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Username:" minWidth="130"/>
                    <TextField fx:id="loginUsernameField" promptText="Enter username" prefWidth="240"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Password:" minWidth="130"/>
                    <PasswordField fx:id="loginPasswordField" promptText="Enter password" prefWidth="240"/>
                </HBox>

                <Button text="Login" onAction="#handleLogin" prefWidth="120"
                        style="-fx-background-color: #1565c0; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20 8 20; -fx-cursor: hand;"/>
                <Label fx:id="loginStatusLabel" wrapText="true" maxWidth="360"/>
            </VBox>
        </Tab>

        <!-- ══ SIGNUP TAB ═════════════════════════════════════════════════════ -->
        <Tab text="Sign Up">
            <VBox spacing="16" style="-fx-padding: 36 48 36 48; -fx-background-color: #f5f5f5;">
                <Label text="Create a new account"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
                <Separator/>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Username:" minWidth="130"/>
                    <TextField fx:id="signupUsernameField" promptText="3-20 chars: letters, numbers, _" prefWidth="240"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Password:" minWidth="130"/>
                    <PasswordField fx:id="signupPasswordField" promptText="Min 8 chars, 1 letter + 1 digit" prefWidth="240"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Confirm Password:" minWidth="130"/>
                    <PasswordField fx:id="signupConfirmPasswordField" promptText="Repeat password" prefWidth="240"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Role:" minWidth="130"/>
                    <ComboBox fx:id="signupRoleCombo" prefWidth="160" value="PATIENT">
                        <items>
                            <javafx.collections.FXCollections fx:factory="observableArrayList">
                                <String fx:value="ADMIN"/>
                                <String fx:value="DOCTOR"/>
                                <String fx:value="PATIENT"/>
                            </javafx.collections.FXCollections>
                        </items>
                    </ComboBox>
                </HBox>

                <Button text="Create Account" onAction="#handleSignup" prefWidth="140"
                        style="-fx-background-color: #1565c0; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20 8 20; -fx-cursor: hand;"/>
                <Label fx:id="signupStatusLabel" wrapText="true" maxWidth="360"/>
            </VBox>
        </Tab>

    </TabPane>
</VBox>
