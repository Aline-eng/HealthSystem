<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.health.healthsystem.controller.MainController"
      spacing="0" style="-fx-background-color: #f5f5f5;">

    <!-- Header -->
    <HBox style="-fx-background-color: #1565c0; -fx-padding: 12 24 12 24;"
          alignment="CENTER_LEFT" spacing="12">
        <Label text="🏥  Healthcare Management System"
               style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="welcomeLabel" style="-fx-text-fill: #bbdefb; -fx-font-size: 12px;"/>
        <Button text="Logout" onAction="#handleLogout"
                style="-fx-background-color: #e53935; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 6 14 6 14;"/>
    </HBox>

    <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE"
             style="-fx-background-color: #f5f5f5;" VBox.vgrow="ALWAYS">

        <!-- ══════════════════════════════════════════════════════════════════
             ADMIN TABS
        ══════════════════════════════════════════════════════════════════════ -->

        <!-- ADMIN: Register Patient -->
        <Tab fx:id="tabRegisterPatient" text="Register Patient">
            <VBox spacing="14" style="-fx-padding: 30; -fx-background-color: #f5f5f5;">
                <Label text="Register New Patient"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
                <Separator/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Patient ID:" minWidth="140"/>
                    <TextField fx:id="patientIdField"
                               promptText="Letters, numbers, hyphens, underscores" prefWidth="300"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Patient Name:" minWidth="140"/>
                    <TextField fx:id="patientNameField" promptText="e.g. John Doe" prefWidth="300"/>
                </HBox>
                <Button text="Register Patient" onAction="#handleRegisterPatient"
                        style="-fx-background-color: #1565c0; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 8 20 8 20; -fx-cursor: hand;"/>
                <Label fx:id="patientStatusLabel" wrapText="true" maxWidth="520"/>
            </VBox>
        </Tab>

        <!-- ADMIN: Register Doctor -->
        <Tab fx:id="tabRegisterDoctor" text="Register Doctor">
            <VBox spacing="14" style="-fx-padding: 30; -fx-background-color: #f5f5f5;">
                <Label text="Register New Doctor"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
                <Separator/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Doctor ID:" minWidth="140"/>
                    <TextField fx:id="doctorIdField"
                               promptText="Letters, numbers, hyphens, underscores" prefWidth="300"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Doctor Name:" minWidth="140"/>
                    <TextField fx:id="doctorNameField" promptText="e.g. Dr. Smith" prefWidth="300"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Specialization:" minWidth="140"/>
                    <TextField fx:id="doctorSpecField" promptText="e.g. Cardiology" prefWidth="300"/>
                </HBox>
                <Button text="Register Doctor" onAction="#handleRegisterDoctor"
                        style="-fx-background-color: #1565c0; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 8 20 8 20; -fx-cursor: hand;"/>
                <Label fx:id="doctorStatusLabel" wrapText="true" maxWidth="520"/>
            </VBox>
        </Tab>

        <!-- ADMIN + PATIENT + DOCTOR: View Doctors -->
        <Tab fx:id="tabViewDoctors" text="View Doctors">
            <VBox spacing="14" style="-fx-padding: 30; -fx-background-color: #f5f5f5;">
                <Label text="Registered Doctors"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
                <Separator/>
                <Button text="Refresh Doctors List" onAction="#handleViewDoctors"
                        style="-fx-background-color: #1565c0; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 8 20 8 20; -fx-cursor: hand;"/>
                <TextArea fx:id="doctorsListArea" editable="false" prefHeight="340"
                          promptText="Click 'Refresh' to load doctors..."
                          style="-fx-font-family: monospace; -fx-font-size: 13px;"/>
            </VBox>
        </Tab>

        <!-- ADMIN: Book Appointment (for any patient) -->
        <Tab fx:id="tabBookAppointmentAdmin" text="Book Appointment">
            <VBox spacing="14" style="-fx-padding: 30; -fx-background-color: #f5f5f5;">
                <Label text="Book an Appointment"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
                <Separator/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Patient ID:" minWidth="140"/>
                    <TextField fx:id="apptPatientIdField" promptText="Registered patient ID" prefWidth="300"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Doctor ID:" minWidth="140"/>
                    <TextField fx:id="apptDoctorIdField" promptText="Registered doctor ID" prefWidth="300"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Date &amp; Time:" minWidth="140"/>
                    <TextField fx:id="apptDateTimeField"
                               promptText="yyyy-MM-dd HH:mm  (e.g. 2025-12-01 14:00)" prefWidth="340"/>
                </HBox>
                <Button text="Book Appointment" onAction="#handleBookAppointment"
                        style="-fx-background-color: #1565c0; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 8 20 8 20; -fx-cursor: hand;"/>
                <Label fx:id="apptStatusLabel" wrapText="true" maxWidth="520"/>
            </VBox>
        </Tab>

        <!-- ADMIN: View All Appointments -->
        <Tab fx:id="tabViewAllAppointments" text="All Appointments">
            <VBox spacing="14" style="-fx-padding: 30; -fx-background-color: #f5f5f5;">
                <Label text="All Scheduled Appointments"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
                <Separator/>
                <Button text="Refresh" onAction="#handleViewAllAppointments"
                        style="-fx-background-color: #1565c0; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 8 20 8 20; -fx-cursor: hand;"/>
                <TextArea fx:id="allAppointmentsArea" editable="false" prefHeight="340"
                          promptText="Click 'Refresh' to load all appointments..."
                          style="-fx-font-family: monospace; -fx-font-size: 13px;"/>
            </VBox>
        </Tab>

        <!-- ADMIN: Add Medical Record -->
        <Tab fx:id="tabAddRecord" text="Add Record">
            <VBox spacing="14" style="-fx-padding: 30; -fx-background-color: #f5f5f5;">
                <Label text="Add Medical Record"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
                <Separator/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Patient ID:" minWidth="140"/>
                    <TextField fx:id="recordPatientIdField" promptText="Registered patient ID" prefWidth="300"/>
                </HBox>
                <HBox spacing="12" alignment="TOP_LEFT">
                    <Label text="Description:" minWidth="140"/>
                    <TextArea fx:id="recordDataField"
                              promptText="Enter medical record description..."
                              prefWidth="340" prefHeight="100" wrapText="true"/>
                </HBox>
                <Button text="Add Record" onAction="#handleAddRecord"
                        style="-fx-background-color: #1565c0; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 8 20 8 20; -fx-cursor: hand;"/>
                <Label fx:id="recordStatusLabel" wrapText="true" maxWidth="520"/>
            </VBox>
        </Tab>

        <!-- ADMIN: View Medical Records (any patient) -->
        <Tab fx:id="tabViewRecordsAdmin" text="View Records">
            <VBox spacing="14" style="-fx-padding: 30; -fx-background-color: #f5f5f5;">
                <Label text="View Medical Records"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
                <Separator/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Patient ID:" minWidth="140"/>
                    <TextField fx:id="viewRecordPatientIdField" promptText="Registered patient ID" prefWidth="280"/>
                    <Button text="View Records" onAction="#handleViewRecords"
                            style="-fx-background-color: #1565c0; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-padding: 8 20 8 20; -fx-cursor: hand;"/>
                </HBox>
                <TextArea fx:id="recordsListArea" editable="false" prefHeight="320"
                          promptText="Enter a Patient ID and click 'View Records'..."
                          style="-fx-font-family: monospace; -fx-font-size: 13px;"/>
            </VBox>
        </Tab>

        <!-- ══════════════════════════════════════════════════════════════════
             PATIENT TABS
        ══════════════════════════════════════════════════════════════════════ -->

        <!-- PATIENT: Book My Appointment (patient ID auto-filled) -->
        <Tab fx:id="tabPatientBook" text="Book Appointment">
            <VBox spacing="14" style="-fx-padding: 30; -fx-background-color: #f5f5f5;">
                <Label text="Book an Appointment"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
                <Separator/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Your Patient ID:" minWidth="140"/>
                    <TextField fx:id="patientSelfIdField" editable="false"
                               style="-fx-background-color: #e3f2fd;" prefWidth="200"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Doctor ID:" minWidth="140"/>
                    <TextField fx:id="patientApptDoctorIdField" promptText="Enter doctor ID" prefWidth="300"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Date &amp; Time:" minWidth="140"/>
                    <TextField fx:id="patientApptDateTimeField"
                               promptText="yyyy-MM-dd HH:mm  (e.g. 2025-12-01 14:00)" prefWidth="340"/>
                </HBox>
                <Button text="Book Appointment" onAction="#handlePatientBookAppointment"
                        style="-fx-background-color: #1565c0; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 8 20 8 20; -fx-cursor: hand;"/>
                <Label fx:id="patientApptStatusLabel" wrapText="true" maxWidth="520"/>
            </VBox>
        </Tab>

        <!-- PATIENT: My Appointments -->
        <Tab fx:id="tabPatientAppointments" text="My Appointments">
            <VBox spacing="14" style="-fx-padding: 30; -fx-background-color: #f5f5f5;">
                <Label text="My Appointments"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
                <Separator/>
                <Button text="Refresh" onAction="#handleViewPatientAppointments"
                        style="-fx-background-color: #1565c0; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 8 20 8 20; -fx-cursor: hand;"/>
                <TextArea fx:id="patientAppointmentsArea" editable="false" prefHeight="340"
                          promptText="Click 'Refresh' to load your appointments..."
                          style="-fx-font-family: monospace; -fx-font-size: 13px;"/>
            </VBox>
        </Tab>

        <!-- PATIENT: My Medical Records -->
        <Tab fx:id="tabPatientRecords" text="My Records">
            <VBox spacing="14" style="-fx-padding: 30; -fx-background-color: #f5f5f5;">
                <Label text="My Medical Records"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
                <Separator/>
                <Button text="Refresh" onAction="#handleViewPatientRecords"
                        style="-fx-background-color: #1565c0; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 8 20 8 20; -fx-cursor: hand;"/>
                <TextArea fx:id="patientRecordsArea" editable="false" prefHeight="340"
                          promptText="Click 'Refresh' to load your records..."
                          style="-fx-font-family: monospace; -fx-font-size: 13px;"/>
            </VBox>
        </Tab>

        <!-- ══════════════════════════════════════════════════════════════════
             DOCTOR TABS
        ══════════════════════════════════════════════════════════════════════ -->

        <!-- DOCTOR: My Schedule -->
        <Tab fx:id="tabDoctorSchedule" text="My Schedule">
            <VBox spacing="14" style="-fx-padding: 30; -fx-background-color: #f5f5f5;">
                <Label text="My Appointment Schedule"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
                <Separator/>
                <Button text="Refresh" onAction="#handleViewDoctorSchedule"
                        style="-fx-background-color: #1565c0; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 8 20 8 20; -fx-cursor: hand;"/>
                <TextArea fx:id="doctorScheduleArea" editable="false" prefHeight="340"
                          promptText="Click 'Refresh' to load your schedule..."
                          style="-fx-font-family: monospace; -fx-font-size: 13px;"/>
            </VBox>
        </Tab>

        <!-- DOCTOR: Add Medical Record for a patient -->
        <Tab fx:id="tabDoctorAddRecord" text="Add Patient Record">
            <VBox spacing="14" style="-fx-padding: 30; -fx-background-color: #f5f5f5;">
                <Label text="Add Medical Record for Patient"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
                <Separator/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Patient ID:" minWidth="140"/>
                    <TextField fx:id="doctorRecordPatientIdField" promptText="Patient ID" prefWidth="300"/>
                </HBox>
                <HBox spacing="12" alignment="TOP_LEFT">
                    <Label text="Description:" minWidth="140"/>
                    <TextArea fx:id="doctorRecordDataField"
                              promptText="Enter medical record description..."
                              prefWidth="340" prefHeight="100" wrapText="true"/>
                </HBox>
                <Button text="Add Record" onAction="#handleDoctorAddRecord"
                        style="-fx-background-color: #1565c0; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 8 20 8 20; -fx-cursor: hand;"/>
                <Label fx:id="doctorRecordStatusLabel" wrapText="true" maxWidth="520"/>
            </VBox>
        </Tab>

        <!-- DOCTOR: View records of a specific patient -->
        <Tab fx:id="tabDoctorViewRecords" text="View Patient Records">
            <VBox spacing="14" style="-fx-padding: 30; -fx-background-color: #f5f5f5;">
                <Label text="View Patient Medical Records"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
                <Separator/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Patient ID:" minWidth="140"/>
                    <TextField fx:id="doctorViewRecordPatientIdField" promptText="Patient ID" prefWidth="280"/>
                    <Button text="View Records" onAction="#handleDoctorViewRecords"
                            style="-fx-background-color: #1565c0; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-padding: 8 20 8 20; -fx-cursor: hand;"/>
                </HBox>
                <TextArea fx:id="doctorPatientRecordsArea" editable="false" prefHeight="320"
                          promptText="Enter a Patient ID and click 'View Records'..."
                          style="-fx-font-family: monospace; -fx-font-size: 13px;"/>
            </VBox>
        </Tab>

    </TabPane>
</VBox>
